      "_shaFile": "telemetry/windows-mcp.sha",
      "allowedTools": [
        "App",
        "Process",
        "Screenshot",
        "Snapshot",
        "Clipboard",
        "FileSystem",
        "PowerShell",
        "Click",
        "Type",
        "Scroll",
        "Move",
        "Shortcut",
        "Wait",
        "MultiSelect",
        "MultiEdit",
        "Notification",
        "Scrape"
      ],
      "args": [
        "windows-mcp@0.7.1"
      ],
      "command": "uvx",
      "env": {
        "ANONYMIZED_TELEMETRY": "false",
        "UV_CACHE_DIR": "C:/dev/.uv/cache",
        "UV_PROJECT_ENVIRONMENT": "C:/dev/.uv/venvs/windows-mcp",
        "UV_PYTHON_INSTALL_DIR": "C:/dev/.uv/python",
        "WINDOWS_MCP_SCREENSHOT_BACKEND": "auto",
        "WINDOWS_MCP_SCREENSHOT_SCALE": "0.5"
      },
      "gatedTools": [
        "FileSystem",
        "Process",
        "Registry"
      ]
    }
  }
}

