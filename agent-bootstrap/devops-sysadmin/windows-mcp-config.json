{
  "_comment": "IronClaw MCP client config for Windows host. Managed by skills/devops-sysadmin/install.ps1 (ADR-015). Do not hand-edit on nodes; edit the canonical source and re-run install.ps1 -Pull.",
  "_versionFile": "telemetry/windows-mcp.version",
  "_windowsMcpVersion": "0.7.1",
  "mcpServers": {
